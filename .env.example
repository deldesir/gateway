# LLM Provider Configuration

# Choose your provider. You only need to set the API key for the provider you intend to use.

# Google Gemini (Default)
# or
# OpenAI
# OPENAI_API_KEY=sk-proj-...
# or
# Anthropic
# ANTHROPIC_API_KEY=sk-ant-...

GEMINI_API_KEY= # Your Google Gemini API Key
OPENAI_API_KEY= # Your OpenAI API Key
ANTHROPIC_API_KEY= # Your Anthropic API Key


# Model Selection (LiteLLM Format)

# Examples:
#   gemini/gemini-1.5-flash
#   openai/gpt-4o-mini
#   anthropic/claude-3-5-sonnet-20240620
#   ollama/llama3

LLM_MODEL= # Your chosen LLM model

# LLM Temperature Setting (0.0 - 1.0)

LLM_TEMPERATURE=0.3 # Temperature setting for the LLM (0.0 - 1.0)


# ── V2 Hermes Agent (architecture_v2_design.md §7.5, §15.3, §16.4) ──
HERMES_HOME=/opt/iiab/ai-gateway/data/hermes
MEMPALACE_PALACE_PATH=/opt/iiab/ai-gateway/data/palace
OMP_NUM_THREADS=1
TOKENIZERS_PARALLELISM=false
LITELLM_BASE_URL=http://localhost:4000/v1
